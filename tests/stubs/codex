#!/usr/bin/env bash
# args: codex <subcmd> ...   Behavior controlled by $STUB_MODE.
sub="${1:-}"
case "$sub" in
  exec)
    # parse -o OUTFILE (review) and -C DIR (run working root)
    _all_args=" $* "
    out=""; cdir=""; _prev=""
    for _a in "$@"; do case "$_prev" in -o) out="$_a" ;; -C|--cd) cdir="$_a" ;; esac; _prev="$_a"; done
    case "$_all_args" in
      *" --sandbox read-only "*) _mode=review ;;
      *" --sandbox workspace-write "*) _mode=run ;;
      *) echo "STUB ERROR: codex must pass --sandbox read-only (review) or workspace-write (run)" >&2; exit 90 ;;
    esac
    if [ "$_mode" = run ]; then
      # executor / write mode: write a file in -C DIR, emit a ===DIGEST=== to stdout
      case "${STUB_MODE:-ok}" in
        quota)    echo "Error: quota exceeded" >&2; exit 1 ;;
        auth)     echo "Error: please sign in" >&2; exit 1 ;;
        notfound) exit 127 ;;
        empty)    exit 0 ;;
        run_noop) printf 'Nothing to do.\n===DIGEST===\nfiles: \ndecisions: none\ncontext: no-op\n===END===\n'; exit 0 ;;
        *) [ -n "$cdir" ] && printf 'stub executor was here\n' > "$cdir/ens_delegate_stub.txt"
           printf 'Implemented the task.\n===DIGEST===\nfiles: ens_delegate_stub.txt\ndecisions: - wrote the stub file\ncontext: stub executor run\n===END===\n'
           exit 0 ;;
      esac
    fi
    # review mode (read-only)
    case "${STUB_MODE:-ok}" in
      quota) echo "Error: quota exceeded" >&2; exit 1 ;;
      auth)  echo "Error: please sign in" >&2; exit 1 ;;
      bad)   [ -n "$out" ] && printf 'not json at all\n' >"$out"; echo "STUB_OK"; exit 0 ;;
      notfound) exit 127 ;;
      mutate) [ -n "$out" ] && printf '{"verdict":"APPROVED","findings":[]}\n' >"$out"; : > "ens_review_mutation_probe.tmp"; echo "STUB_OK"; exit 0 ;;
      mutate_tracked) [ -n "$out" ] && printf '{"verdict":"APPROVED","findings":[]}\n' >"$out"; echo "REVIEWER-OVERWROTE" > tracked.txt; echo "STUB_OK"; exit 0 ;;
      mutate_untracked) [ -n "$out" ] && printf '{"verdict":"APPROVED","findings":[]}\n' >"$out"; echo "REVIEWER-CLOBBERED" > data.txt; echo "STUB_OK"; exit 0 ;;
    esac
    [ -n "$out" ] && printf '{"verdict":"CHANGES","findings":[{"file":"x.py","line":1,"severity":"low","issue":"stub"}]}\n' >"$out"
    echo "STUB_OK" ;;
  doctor) [ "${STUB_MODE:-ok}" = "auth" ] && { echo '{"auth":"logged_out"}'; exit 0; }; echo '{"auth":"ok"}' ;;
  app-server)
    # emulate JSON-RPC: read lines, answer model/list (id 2)
    while IFS= read -r line; do
      case "$line" in
        *'"id":2'*) printf '{"jsonrpc":"2.0","id":2,"result":{"data":[{"id":"gpt-5.5","model":"gpt-5.5","isDefault":true},{"id":"gpt-5.4","model":"gpt-5.4"}]}}\n' ;;
      esac
    done ;;
  *) echo "STUB_OK" ;;
esac
